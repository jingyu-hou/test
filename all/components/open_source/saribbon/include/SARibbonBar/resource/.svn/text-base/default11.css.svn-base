 QPushButton[text="nihao"]
 {
	border: 1px solid #ff0000;
	padding: 4px;
	max-width: 40px;
	background: #ff0000;
	background-position: #ff0000;
	text-decoration: none;
	table-layout: auto;
	border-spacing: 0px;
	color:White;
}
QPushButton::hover{
	background:#00ff00;	
}
QPushButton::pressed
{
	background:#0000ff;
	color:red;
}



